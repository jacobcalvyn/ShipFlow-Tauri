{
  "name": "shipflow3-tauri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "prepare:service-binary": "node ./scripts/prepare-service-binary.mjs",
    "build:bundle": "npm run prepare:service-binary && tauri build --config src-tauri/tauri.bundle.conf.json",
    "test": "vitest run --exclude src/features/sheet/components/SheetTable.benchmark.test.tsx",
    "bench:table": "vitest run src/features/sheet/components/SheetTable.benchmark.test.tsx --environment jsdom --reporter=verbose",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.3.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vitest": "^2.1.8"
  }
}
